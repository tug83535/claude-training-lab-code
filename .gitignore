# ─────────────────────────────────────────────
# Excel temporary / lock files
# ─────────────────────────────────────────────
~$*.xlsx
~$*.xls
~$*.xlsm
~$*.xlsb
*.xlk

# ─────────────────────────────────────────────
# Python cache & virtual environments
# ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/
.venv/
venv/
env/
*.egg

# ─────────────────────────────────────────────
# macOS system files
# ─────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride

# ─────────────────────────────────────────────
# Windows system files
# ─────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ─────────────────────────────────────────────
# VS Code / editor settings
# ─────────────────────────────────────────────
.vscode/
*.code-workspace

# ─────────────────────────────────────────────
# Python output folders (runtime artifacts)
# ─────────────────────────────────────────────
outputs/

# ─────────────────────────────────────────────
# Logs
# ─────────────────────────────────────────────
*.log
