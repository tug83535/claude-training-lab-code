# ============================================================
# APCLDmerge Project — .gitignore
# ============================================================

# ------------------------------------------------------------
# Microsoft Excel — Temporary / Lock Files
# ------------------------------------------------------------
~$*.xlsx
~$*.xlsm
~$*.xls
~$*.xlsb
*.~lock.*

# ------------------------------------------------------------
# Windows Junk Files
# ------------------------------------------------------------
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ------------------------------------------------------------
# macOS Junk Files
# ------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ------------------------------------------------------------
# Python Cache & Virtual Environments
# ------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.env
.venv
venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/

# ------------------------------------------------------------
# Editor Temporary Files
# ------------------------------------------------------------
*.swp
*.swo
*.tmp
*.bak
*.orig
*~

# ------------------------------------------------------------
# Log Files
# ------------------------------------------------------------
*.log

# ------------------------------------------------------------
# OS-Generated Files
# ------------------------------------------------------------
.directory

# ------------------------------------------------------------
# Video / Audio Media Files (too large for git)
# Folder structure is preserved via .gitkeep files.
# ------------------------------------------------------------
*.mp3
*.mp4
*.wav
*.mov
*.avi
*.mkv
*.m4a

# ZeroInstall generated run outputs
RecTrial/UniversalToolkit/python/ZeroInstall/outputs/
